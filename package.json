{
  "name": "rust-import-organizer",
  "displayName": "Rust Import Organizer",
  "description": "Organize, sort, group, and auto-import Rust use statements — with unused removal, Cargo.toml awareness, and disambiguation",
  "version": "0.2.0",
  "publisher": "hugomartinezf",
  "repository": "https://github.com/hugomf/vscode-rust-oi",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rust-import-organizer.organizeImports",
        "title": "Organize Rust Imports",
        "category": "Rust"
      },
      {
        "command": "rust-import-organizer.organizeImportsWithAutoImport",
        "title": "Organize Rust Imports + Auto Import",
        "category": "Rust"
      }
    ],
    "keybindings": [
      {
        "command": "rust-import-organizer.organizeImports",
        "key": "shift+alt+o",
        "mac": "shift+option+o",
        "when": "editorTextFocus && editorLangId == rust"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "rust-import-organizer.organizeImports",
          "when": "editorLangId == rust",
          "group": "1_modification"
        },
        {
          "command": "rust-import-organizer.organizeImportsWithAutoImport",
          "when": "editorLangId == rust",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Rust Import Organizer",
      "properties": {
        "rust-import-organizer.groupImports": {
          "type": "boolean",
          "default": true,
          "description": "Group imports into std / external / local / cfg sections."
        },
        "rust-import-organizer.sortAlphabetically": {
          "type": "boolean",
          "default": true,
          "description": "Sort imports alphabetically within each group."
        },
        "rust-import-organizer.blankLineBetweenGroups": {
          "type": "boolean",
          "default": true,
          "description": "Insert a blank line between import groups."
        },
        "rust-import-organizer.collapseSingleImports": {
          "type": "boolean",
          "default": false,
          "description": "Collapse grouped imports filtered to a single item (e.g. use std::path::{Path} → use std::path::Path;)."
        },
        "rust-import-organizer.removeUnused": {
          "type": "boolean",
          "default": true,
          "description": "Remove unused imports. Set to false to only sort and group without removing anything."
        },
        "rust-import-organizer.enableAutoImport": {
          "type": "boolean",
          "default": true,
          "description": "Auto-import unresolved symbols when running 'Organize + Auto Import'. Requires Rust Analyzer."
        },
        "rust-import-organizer.organizeOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically organize imports when saving a Rust file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package --allow-missing-repository",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.2"
  }
}